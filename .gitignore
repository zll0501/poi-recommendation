*.pt
*.pth
*.ckpt

# Generated experiment results
results/predictions/*
!results/predictions/.gitkeep
results/metrics/*
!results/metrics/.gitkeep
results/figures/*
!results/figures/.gitkeep
results/logs/*
!results/logs/.gitkeep

# Temporary files
*.tmp
*.log
.DS_Store
Thumbs.db
